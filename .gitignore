# Feature engineering v2 fine-tune experiments (2026-04-08) — intermediate,
# not tracked (too large, reproducible from config + logs)
checkpoints/act1_v2features/
checkpoints/act1_v2features_200iter/

# 2026-04-09 aux-resume overnight run — 21 intermediate checkpoints (~520 MB)
# + offline_data episode dumps. The 3 promoted candidates
# (aux_final_iter1999.pt, aux_iter1050.pt, aux_iter1500.pt) live in
# checkpoints/act1/ and ARE tracked via LFS. The full run directory is only
# kept on disk for ad-hoc re-eval / splice experiments.
checkpoints/act1_aux_overnight/

# 2026-04-09 PM retrieval-head aux-resume — 9 intermediate checkpoints (2000-2199
# in 25-iter steps, ~65 MB). The promoted candidate retrieval_final_iter2175.pt
# lives in checkpoints/act1/ and is LFS-tracked. Intermediate checkpoints are
# kept on disk for ablation sweeps but not committed.
checkpoints/act1_retrieval_200iter/

# 2026-04-09 PM 20-iter smoke training (verification run after wiring
# SymbolicFeaturesHead before the full 200-iter training). Disposable.
checkpoints/act1_symbolic_smoke/

# Splice experiments — research-only, not promoted.
checkpoints/splice/

# Git-bash on Windows accidentally materializes `/dev/null` redirects as
# empty literal `dev/null/` directories in the repo root. Harmless but noisy.
dev/
